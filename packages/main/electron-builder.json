{
  "appId": "com.cosmosh.app",
  "productName": "Cosmosh",
  "directories": {
    "buildResources": "resources",
    "output": "release"
  },
  "npmRebuild": false,
  "files": [
    "dist/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "resources-runtime/node_modules",
      "to": "node_modules",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "../renderer/dist",
      "to": "renderer",
      "filter": [
        "**/*"
      ]
    }
  ],
  "mac": {
    "category": "public.app-category.developer-tools",
    "target": [
      "dmg",
      "zip"
    ]
  },
  "win": {
    "target": [
      "nsis"
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowElevation": true,
    "allowToChangeInstallationDirectory": true,
    "perMachine": false,
    "createDesktopShortcut": false,
    "createStartMenuShortcut": false,
    "shortcutName": "Cosmosh",
    "menuCategory": "Cosmosh",
    "runAfterFinish": true,
    "deleteAppDataOnUninstall": false,
    "include": "resources/installer.nsh"
  },
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "category": "Development",
    "maintainer": "agoudbg <agoudbg+cosmosh@gmail.com>",
    "executableName": "cosmosh",
    "artifactName": "${productName}-${version}-${arch}.${ext}"
  },
  "deb": {
    "packageName": "cosmosh",
    "depends": [
      "libasound2 | libasound2t64",
      "libatk-bridge2.0-0",
      "libatk1.0-0",
      "libatspi2.0-0",
      "libc6",
      "libcairo2",
      "libdrm2",
      "libgbm1",
      "libglib2.0-0",
      "libgtk-3-0",
      "libnotify4",
      "libnss3",
      "libpango-1.0-0",
      "libsecret-1-0",
      "libuuid1",
      "libx11-6",
      "libx11-xcb1",
      "libxcb-dri3-0",
      "libxcb1",
      "libxcomposite1",
      "libxdamage1",
      "libxext6",
      "libxfixes3",
      "libxkbcommon0",
      "libxrandr2",
      "libxss1",
      "libxtst6",
      "libxshmfence1",
      "xdg-utils"
    ]
  }
}
