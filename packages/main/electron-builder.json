{
  "appId": "com.cosmosh.app",
  "productName": "Cosmosh",
  "directories": {
    "buildResources": "resources",
    "output": "release"
  },
  "npmRebuild": false,
  "files": [
    "dist/**/*",
    "node_modules/**/*",
    "node_modules/.prisma/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "resources-runtime/node_modules/@prisma/client",
      "to": "node_modules/@prisma/client",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "resources-runtime/node_modules/.prisma",
      "to": "node_modules/.prisma",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "../renderer/dist",
      "to": "renderer",
      "filter": [
        "**/*"
      ]
    }
  ],
  "mac": {
    "category": "public.app-category.developer-tools",
    "target": [
      "dmg",
      "zip"
    ]
  },
  "win": {
    "target": [
      "nsis",
      "portable"
    ]
  },
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "category": "Development",
    "maintainer": "agoudbg <agoudbg+cosmosh@gmail.com>",
    "executableName": "cosmosh",
    "artifactName": "${productName}-${version}-${arch}.${ext}"
  },
  "deb": {
    "packageName": "cosmosh"
  }
}
