{
  "name": "@cosmosh/main",
  "productName": "Cosmosh",
  "version": "0.1.0+116",
  "private": true,
  "description": "Cosmosh Electron Main Process",
  "author": {
    "name": "agoudbg",
    "email": "agoudbg+cosmosh@gmail.com"
  },
  "homepage": "https://github.com/agoudbg/cosmosh",
  "main": "./dist/index.js",
  "scripts": {
    "predev": "pnpm --filter @cosmosh/api-contract build && pnpm --filter @cosmosh/i18n build",
    "dev": "tsc -p tsconfig.json && electron dist/index.js",
    "prebuild": "node ./scripts/cleanup-legacy-artifacts.cjs && node ./scripts/release-unlock-prisma-locks.cjs && pnpm --filter @cosmosh/backend build && pnpm --filter @cosmosh/api-contract build && pnpm --filter @cosmosh/i18n build && node ./scripts/ensure-sqlcipher-native.cjs && node ./scripts/sync-prisma-client.cjs && node ./scripts/sync-backend-runtime.cjs && node ./scripts/generate-installer-strings.mjs && pnpm --filter @cosmosh/renderer build",
    "build": "tsc && electron-builder",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "devDependencies": {
    "@cosmosh/api-contract": "workspace:*",
    "@cosmosh/backend": "workspace:*",
    "@cosmosh/i18n": "workspace:*",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "cross-env": "^7.0.3",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "eslint": "^9.17.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^15.13.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1"
  }
}
