{
  "name": "@cosmosh/main",
  "version": "0.1.0",
  "private": true,
  "description": "Cosmosh Electron Main Process",
  "author": {
    "name": "agoudbg",
    "email": "agoudbg+cosmosh@gmail.com"
  },
  "homepage": "https://github.com/agoudbg/cosmosh",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsc -p tsconfig.json && electron dist/index.js",
    "prebuild": "pnpm --filter @cosmosh/renderer build",
    "build": "tsc && electron-builder",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@cosmosh/i18n": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.17.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^15.13.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1"
  }
}
