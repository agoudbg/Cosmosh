{
  "name": "@cosmosh/backend",
  "version": "0.1.0+116",
  "private": true,
  "type": "module",
  "description": "Cosmosh Backend API Server (Hono)",
  "main": "./dist/index.js",
  "scripts": {
    "predev": "pnpm --filter @cosmosh/api-contract build && pnpm --filter @cosmosh/i18n build && prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push --skip-generate",
    "db:init": "tsx src/scripts/init-db.ts",
    "completion:generate": "node ./scripts/generate-inshellisense.mjs",
    "dev:runtime": "tsx src/index.ts",
    "dev:runtime:watch": "tsx watch src/index.ts",
    "dev": "pnpm run dev:runtime:watch",
    "prebuild": "pnpm --filter @cosmosh/api-contract build && pnpm --filter @cosmosh/i18n build && prisma generate",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@cosmosh/api-contract": "workspace:*",
    "@cosmosh/i18n": "workspace:*",
    "@hono/node-server": "^1.19.11",
    "@prisma/client": "^6.19.2",
    "better-sqlite3-multiple-ciphers": "^12.6.2",
    "hono": "^4.12.7",
    "node-pty": "1.2.0-beta.11",
    "ssh2": "^1.17.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.4.0",
    "@types/ssh2": "^1.15.5",
    "@types/ws": "^8.18.1",
    "@withfig/autocomplete": "^2.692.3",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prisma": "^6.19.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
