{
  "name": "@cosmosh/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cosmosh Backend API Server (Hono)",
  "main": "./dist/index.js",
  "scripts": {
    "predev": "pnpm --filter @cosmosh/api-contract build && pnpm --filter @cosmosh/i18n build && prisma generate",
    "db:generate": "prisma generate",
    "db:init": "tsx src/scripts/init-db.ts",
    "dev": "tsx watch src/index.ts",
    "prebuild": "pnpm --filter @cosmosh/api-contract build && pnpm --filter @cosmosh/i18n build && prisma generate",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "@cosmosh/api-contract": "workspace:*",
    "@cosmosh/i18n": "workspace:*",
    "hono": "^4.6.14",
    "@hono/node-server": "^1.13.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^15.13.0",
    "prettier": "^3.4.2",
    "prisma": "^6.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1"
  }
}
